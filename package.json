{
  "name": "@1money/protocol-ts-sdk",
  "version": "2.0.2",
  "description": "ts sdk for 1Money protocol network",
  "main": "lib/index.js",
  "module": "es/index.js",
  "exports": {
    ".": {
      "import": "./es/index.js",
      "require": "./lib/index.js",
      "types": "./es/index.d.ts"
    },
    "./api": {
      "import": "./es/api/index.js",
      "require": "./lib/api/index.js",
      "types": "./es/api/index.d.ts"
    },
    "./client": {
      "import": "./es/client/index.js",
      "require": "./lib/client/index.js",
      "types": "./es/client/index.d.ts"
    },
    "./utils": {
      "import": "./es/utils/index.js",
      "require": "./lib/utils/index.js",
      "types": "./es/utils/index.d.ts"
    },
    "./package.json": "./package.json"
  },
  "unpkg": "umd/1money-protocol-ts-sdk.min.js",
  "scripts": {
    "test": "nyc mocha --config .mocharc.js",
    "test:integration": "cross-env RUN_INTEGRATION_TESTS=true mocha --config .mocharc.integration.js",
    "test:integration:local": "cross-env RUN_INTEGRATION_TESTS=true INTEGRATION_TEST_NETWORK=local mocha --config .mocharc.integration.js",
    "test:integration:testnet": "cross-env RUN_INTEGRATION_TESTS=true INTEGRATION_TEST_NETWORK=testnet mocha --config .mocharc.integration.js",
    "test:integration:issue": "cross-env RUN_INTEGRATION_TESTS=true INTEGRATION_TEST_NETWORK=testnet mocha --config .mocharc.integration.js --grep \"1\\. Issue Token\"",
    "test:all": "npm run test && npm run test:integration",
    "lint": "npm run lint:prettier && npm run lint:es",
    "lint:fix": "npm run lint:prettier_fix && npm run lint:es_fix",
    "lint:es": "eslint src/",
    "lint:es_fix": "eslint src/ --fix",
    "lint:prettier": "prettier --check src/",
    "lint:prettier_fix": "prettier --write src/",
    "lint:commit": "commitlint --edit",
    "new": "omni new",
    "build": "omni build",
    "build:remote": "cross-env RUN_ENV=remote omni build",
    "release": "omni release",
    "prepare": "husky"
  },
  "lint-staged": {
    "src/**/*.{js,jsx,ts,tsx}": [
      "npm run lint:es_fix",
      "npm run lint:prettier_fix"
    ]
  },
  "keywords": [],
  "author": "",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/1Money-Co/1money-protocol-ts-sdk"
  },
  "peerDependencies": {
    "@ethereumjs/rlp": ">=10.0.0 <11.0.0",
    "axios": ">=1.12.0 <2.0.0",
    "viem": ">=2.0.0 <3.0.0"
  },
  "devDependencies": {
    "@babel/core": "~7.26.10",
    "@babel/plugin-transform-runtime": "~7.26.10",
    "@babel/preset-env": "~7.26.9",
    "@babel/preset-typescript": "~7.26.0",
    "@babel/runtime-corejs3": "~7.26.10",
    "@commitlint/cli": "~20.5.0",
    "@commitlint/config-conventional": "~20.5.0",
    "@ethereumjs/rlp": "^10.0.0",
    "@noble/secp256k1": "2.3.0",
    "@omni-door/cli": "~3.2.2",
    "@rollup/plugin-alias": "~5.1.1",
    "@rollup/plugin-babel": "~6.0.4",
    "@rollup/plugin-commonjs": "~28.0.3",
    "@rollup/plugin-json": "~6.1.0",
    "@rollup/plugin-node-resolve": "~16.0.1",
    "@rollup/plugin-terser": "^1.0.0",
    "@rollup/plugin-typescript": "^12.1.2",
    "@types/chai": "4.3.17",
    "@types/mocha": "10.0.7",
    "@types/node": "~18.19.39",
    "typescript-eslint": "~8.57.1",
    "axios": "~1.12.0",
    "chai": "4.5.0",
    "cross-env": "^7.0.3",
    "del": "5.1.0",
    "detect-port": "1.3.0",
    "dotenv": "^16.5.0",
    "@eslint/js": "~9.23.0",
    "eslint": "~9.23.0",
    "eslint-config-prettier": "~10.1.8",
    "eslint-plugin-prettier": "~5.5.5",
    "husky": "9.1.7",
    "ip": "1.1.5",
    "lint-staged": "15.4.3",
    "mocha": "11.7.5",
    "nyc": "17.0.0",
    "prettier": "~3.5.0",
    "prettier-eslint": "^16.3.0",
    "puppeteer": "^24.40.0",
    "rollup": "~4.60.0",
    "rollup-plugin-polyfill-node": "^0.13.0",
    "ts-loader": "9.5.1",
    "ts-patch": "~3.2.1",
    "tsc-alias": "^1.8.16",
    "tsconfig-paths": "~3.9.0",
    "tslib": "^2.6.3",
    "tsx": "^4.17.0",
    "typescript": "~5.8.3",
    "typescript-transform-paths": "~3.5.5",
    "viem": "^2.30.0"
  },
  "pnpm": {
    "overrides": {
      "minimatch@<3.1.4": "3.1.4",
      "minimatch@>=5.0.0 <5.1.8": "5.1.8",
      "minimatch@>=9.0.0 <9.0.7": "9.0.7",
      "flatted@<=3.4.1": "3.4.2",
      "serialize-javascript@<=7.0.2": "7.0.4",
      "basic-ftp@<5.2.0": "5.2.0"
    }
  }
}
